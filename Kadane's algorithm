class Solution {
    int maxSubarraySum(int[] arr) {
        
        int sum=arr[0];
        int ms=arr[0];
        for(int i=1;i<arr.length;i++)
        {
            if(sum<0)
            {
                sum=0;
            }
            sum+=arr[i];
            ms=Math.max(ms,sum);
        }
        return ms;
    }
}
