class Solution {
    static void rotateArr(int arr[], int d) {
        // code here
        int n=arr.length;
        int[] res=new int[n];
        for(int i=0;i<n;i++)
        {
            res[i]=arr[(i+d)%n];
        }
        for(int i=0;i<n;i++)
        {
        arr[i]=res[i];
        }
        
    }
}
