class Solution {
    public int maxProfit(int[] prices) {
        // Code here
        int n=prices.length;
        int m=prices[0];
        int pf=0;
        for(int i=1;i<n;i++)
        {
            int val=(prices[i]-m);
            m=Math.min(m,prices[i]);
            pf=Math.max(pf,val);
            
        }
        return pf;
    }
}
