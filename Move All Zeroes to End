class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
        int n=arr.length;
        int in=0;
        for(int i=0;i<n;i++)
        {
            if(arr[i]!=0)
             {
                 int t=arr[in];
                 arr[in]=arr[i];
                 arr[i]=t;
                 in++;
             }   
        }
    }
}
